<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto Backup rules (Android 6+, pre-Android 12).
  Excludes the auth_prefs DataStore so the JWT and user JSON do not sync to Google Drive.
-->
<full-backup-content>
    <exclude domain="file" path="datastore/auth_prefs.preferences_pb"/>
</full-backup-content>
