<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup + device-transfer rules (Android 12+).
  Excludes the auth_prefs DataStore from cloud backup AND device-to-device transfer
  so the JWT and user JSON never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
